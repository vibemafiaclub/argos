generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // Supabase: connection pooling 우회용 (마이그레이션 시)
}

// ─── Organization ──────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  githubOrg String?  @unique @map("github_org")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships OrgMembership[]
  projects    Project[]

  @@map("organizations")
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash") // bcrypt hash
  name         String
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  OrgMembership[]
  cliTokens    CliToken[]
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]

  @@map("users")
}

// ─── OrgMembership ─────────────────────────────────────────────────────────

model OrgMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  orgId     String   @map("org_id")
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_memberships")
}

enum OrgRole {
  OWNER
  MEMBER
}

// ─── CliAuthRequest ────────────────────────────────────────────────────────
// 브라우저 기반 CLI 인증 흐름의 pending state 관리

model CliAuthRequest {
  id        String    @id @default(cuid())
  state     String    @unique  // CLI가 생성한 랜덤 토큰
  token     String?            // 승인 후 발급된 JWT
  approved  Boolean   @default(false)
  denied    Boolean   @default(false)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("cli_auth_requests")
}

// ─── CliToken ──────────────────────────────────────────────────────────────
// ~/.argos/config.json에 저장된 장기 JWT의 revocation 관리

model CliToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")  // SHA-256(JWT), revocation 체크용
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cli_tokens")
}

// ─── Project ───────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]
  dailyStats   DailyProjectStat[]

  @@unique([orgId, slug])
  @@map("projects")
}

// ─── DailyProjectStat ──────────────────────────────────────────────────────
// 하루 단위로 pre-aggregated된 dashboard 지표.
// past 날짜에 대해 lazy하게 계산/upsert하고, 이후 조회는 이 테이블에서만 읽는다.
// "오늘"은 아직 데이터가 움직이므로 캐시하지 않고 매 요청마다 live 집계한다.

model DailyProjectStat {
  projectId           String   @map("project_id")
  date                DateTime @db.Date   // UTC-local day

  sessionCount        Int      @default(0) @map("session_count")
  turnCount           Int      @default(0) @map("turn_count")
  activeUserCount     Int      @default(0) @map("active_user_count")

  inputTokens         BigInt   @default(0) @map("input_tokens")
  outputTokens        BigInt   @default(0) @map("output_tokens")
  cacheReadTokens     BigInt   @default(0) @map("cache_read_tokens")
  cacheCreationTokens BigInt   @default(0) @map("cache_creation_tokens")
  estimatedCostUsd    Float    @default(0) @map("estimated_cost_usd")

  // activeUserIds: 범위 쿼리에서 DISTINCT 병합용 (set union 후 size)
  activeUserIds       Json     @default("[]") @map("active_user_ids")
  // { skillName: count, ... }
  skillCounts         Json     @default("{}") @map("skill_counts")
  // { agentType: count, ... }
  agentCounts         Json     @default("{}") @map("agent_counts")
  // { model: totalTokens, ... }
  modelTokens         Json     @default("{}") @map("model_tokens")
  // [{ userId, name, sessionCount, inputTokens, outputTokens, cost, skillCalls, agentCalls }, ...]
  userStats           Json     @default("[]") @map("user_stats")

  computedAt          DateTime @default(now()) @map("computed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, date])
  @@map("daily_project_stats")
}

// ─── ClaudeSession ─────────────────────────────────────────────────────────
// Claude Code 세션 하나 = 하나의 row
// id는 Claude Code의 session_id를 그대로 사용 (중복 방지)

model ClaudeSession {
  id             String    @id  // Claude Code session_id
  projectId      String    @map("project_id")
  userId         String    @map("user_id")
  transcriptPath String?   @map("transcript_path")
  startedAt      DateTime  @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")
  // transcript.jsonl의 type="summary" 라인에서 추출 (주로 /compact 또는 resume 시 존재)
  // 없으면 응답 조립 단계에서 첫 HUMAN 메시지를 fallback title로 사용
  title          String?
  summary        String?

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  usageRecords UsageRecord[]
  messages     Message[]

  @@index([projectId, startedAt])
  @@index([userId, startedAt])
  @@map("claude_sessions")
}

// ─── Event ─────────────────────────────────────────────────────────────────
// Claude Code hook 이벤트 하나 = 하나의 row
// 고빈도 테이블 (팀 10명, 하루 수천 건)

model Event {
  id           String    @id @default(cuid())
  sessionId    String    @map("session_id")
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  eventType    EventType @map("event_type")
  toolName     String?   @map("tool_name")
  toolInput    Json?     @map("tool_input")
  toolResponse String?   @map("tool_response")
  exitCode     Int?      @map("exit_code")

  // 파생 필드 (쿼리 성능을 위해 저장 시 계산)
  isSkillCall    Boolean @default(false) @map("is_skill_call")
  skillName      String? @map("skill_name")
  isSlashCommand Boolean @default(false) @map("is_slash_command")  // slash command(/skill-name) vs Skill tool 직접 호출 구분
  isAgentCall    Boolean @default(false) @map("is_agent_call")
  agentType      String? @map("agent_type")
  agentDesc      String? @map("agent_desc")
  agentId        String? @map("agent_id") // 서브에이전트 이벤트인 경우 agent_id 값 (최상위 이벤트는 null)

  timestamp DateTime @default(now())

  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([projectId, isSkillCall, timestamp])
  @@index([projectId, isAgentCall, timestamp])
  @@map("events")
}

enum EventType {
  SESSION_START
  PRE_TOOL_USE
  POST_TOOL_USE
  STOP
  SUBAGENT_STOP
}

// ─── UsageRecord ───────────────────────────────────────────────────────────
// Stop/SubagentStop 이벤트 시 transcript에서 추출한 토큰 사용량
// 집계 쿼리의 주 대상 테이블

model UsageRecord {
  id                  String   @id @default(cuid())
  sessionId           String   @map("session_id")
  userId              String   @map("user_id")
  projectId           String   @map("project_id")
  inputTokens         Int      @default(0) @map("input_tokens")
  outputTokens        Int      @default(0) @map("output_tokens")
  cacheCreationTokens Int      @default(0) @map("cache_creation_tokens")
  cacheReadTokens     Int      @default(0) @map("cache_read_tokens")
  estimatedCostUsd    Float?   @map("estimated_cost_usd")
  model               String?
  isSubagent          Boolean  @default(false) @map("is_subagent")
  timestamp           DateTime @default(now())

  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([userId, timestamp])
  @@map("usage_records")
}

// ─── Message ───────────────────────────────────────────────────────────────
// 세션별 전체 대화 이력 (transcript.jsonl 파싱 결과)
// Stop/SubagentStop 이벤트 시 bulk insert
// 팀 차원의 프롬프트 패턴 분석 및 세션 상세 조회에 사용

model Message {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  role      MessageRole // HUMAN | ASSISTANT | TOOL
  content   String      // HUMAN/ASSISTANT: text 블록. TOOL: tool_result 텍스트. 50,000자 truncation
  sequence  Int         // 세션 내 메시지 순서 (0-based, best-effort — 실시간 TOOL row는 임시값 후 Stop에서 재할당)
  timestamp DateTime    // transcript 원본 타임스탬프

  // TOOL role 전용 — 다른 role에서는 모두 null
  toolName   String? @map("tool_name")
  toolInput  Json?   @map("tool_input")
  toolUseId  String? @map("tool_use_id")
  durationMs Int?    @map("duration_ms")

  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, toolUseId])
  @@map("messages")
}

enum MessageRole {
  HUMAN
  ASSISTANT
  TOOL
}
