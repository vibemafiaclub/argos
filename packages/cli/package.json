{
  "name": "argos-ai",
  "version": "0.1.14",
  "type": "module",
  "bin": {
    "argos": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/add-shebang.js",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7",
    "chalk": "^5",
    "commander": "^12",
    "ora": "^8"
  },
  "devDependencies": {
    "@argos/shared": "workspace:*",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
